{
  "manifest_version": 3,
  "name": "Code Safety Checker",
  "version": "0.1.0",
  "description": "Phat hien code snippet khong an toan tren StackOverflow/GitHub bang LLM API.",
  "host_permissions": [
    "https://*.stackoverflow.com/*",
    "https://*.github.com/*"
  ],
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.stackoverflow.com/*",
        "https://*.github.com/*"
      ],
      "js": [
        "src/content/injector.js",
        "src/content/detector.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
